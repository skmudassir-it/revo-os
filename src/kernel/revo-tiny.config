# Revo OS v1.1 — Tiny Kernel Configuration
# Target: ~3-4 MB vmlinuz (xz compressed)
# Base: make tinyconfig + essential enables only
#
# Apply with: cp this .config && make olddefconfig && make bzImage
#
# Strategy: ~550 config options vs Ubuntu's 5000+, Alpine virt's 2800+
# Remove: sound, GPU/DRM, WiFi/BT, btrfs/xfs/zfs/nfs, IPv6, KVM, firmware

# Architecture & CPU
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=8

# EFI Boot (kernel IS the bootloader)
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_HANDOVER_PROTOCOL=y
CONFIG_EFI_MIXED=n

# Core filesystems (built-in, not modules)
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_OVERLAY_FS=y

# Pseudo filesystems
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y

# Device Mapper (for dm-verity)
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=n
CONFIG_DM_VERITY_FEC=n

# Container support
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_CGROUP_NET_CLASSID=y

# Security (seccomp for containers)
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Networking (IPv4 only — smallest footprint)
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y

# Storage drivers
CONFIG_BLK_DEV_NVME=y
CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_SD=y

# Network drivers
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_PCI=y

# Loop device (for container images)
CONFIG_BLK_DEV_LOOP=y

# FAT (EFI System Partition)
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_MSDOS_FS=y

# Compression (kernel self-decompression)
CONFIG_KERNEL_GZIP=n
CONFIG_KERNEL_BZIP2=n
CONFIG_KERNEL_LZMA=n
CONFIG_KERNEL_XZ=y
CONFIG_KERNEL_LZO=n
CONFIG_KERNEL_LZ4=n

# Crypto (for dm-verity SHA256)
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_HASH=y
