#!/bin/busybox sh
# ornetd — Revo OS AI Inference Dispatcher v1.6.0
# Manages AI models and inference via llama.cpp with GPU acceleration
# Part of the Ornet subsystem: kernel-native AI inference for Revo OS

set -e

# ─── Configuration ───
ORNETD_VERSION="1.6.0"
ORNETD_LOG="/var/log/ornetd.log"
ORNETD_PIDFILE="/run/ornetd.pid"
ORNETD_SOCKET="/run/ornetd.sock"
MODEL_DIR="${MODEL_DIR:-/revo/ai/models}"
MODEL_FILE="${MODEL_FILE:-ornith-1.0-9b-Q4_K_M.gguf}"
MODEL_PATH="$MODEL_DIR/$MODEL_FILE"
LLAMA_CLI="${LLAMA_CLI:-/usr/bin/llama-cli}"
DEFAULT_THREADS="${DEFAULT_THREADS:-4}"
DEFAULT_CTX="${DEFAULT_CTX:-4096}"
DEFAULT_TEMP="${DEFAULT_TEMP:-0.7}"
MAX_TOKENS="${MAX_TOKENS:-512}"

# ─── v1.6.0: GPU Configuration ───
GPU_BACKEND="${GPU_BACKEND:-auto}"         # auto, cuda, vulkan, rocm, oneapi, cpu
GPU_LAYERS="${GPU_LAYERS:-0}"              # 0=auto (all layers if GPU), N=specific count
GPU_SPLIT="${GPU_SPLIT:-}"                 # GPU/CPU split ratio (e.g. "70/30")
GPU_DIR="${GPU_DIR:-/revo/gpu}"            # GPU runtime libraries location
MULTI_MODEL="${MULTI_MODEL:-0}"            # Enable multi-model hot-swap

# ─── Logging ───
log() { echo "[ornetd] $(date '+%H:%M:%S') $*" >> "$ORNETD_LOG" 2>/dev/null; echo "[ornetd] $*"; }
die()  { log "FATAL: $*"; exit 1; }

# ─── Help ───
usage() {
    echo "ornetd v$ORNETD_VERSION — Revo OS AI Inference Dispatcher"
    echo ""
    echo "Usage: ornetd <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  start [--gpu cuda|vulkan] [--cpu-only] [--split 70/30]"
    echo "                        Start the inference dispatcher daemon"
    echo "  stop                   Stop the dispatcher daemon"
    echo "  status                 Check dispatcher + GPU status"
    echo "  infer <prompt>         Run a single inference (synchronous)"
    echo "  chat                   Start interactive chat session"
    echo "  model-info             Show loaded model information"
    echo "  model list             List all models on RevoAI volume"
    echo "  model switch <name>    Hot-swap to a different model"
    echo "  model download <name>  Download a model from HuggingFace"
    echo "  download               Download Ornith-1 9B GGUF"
    echo "  version                Show version"
    echo ""
    echo "GPU Options (v1.6.0):"
    echo "  --gpu cuda|vulkan|rocm|oneapi   Force GPU backend"
    echo "  --cpu-only                      Disable GPU, CPU inference only"
    echo "  --split 70/30                   Tensor offload ratio (GPU/CPU)"
    echo ""
}

# ─── v1.6.0: GPU Detection ───
gpu_detect() {
    # Run revo-gpu if available, otherwise fall back to basic checks
    if [ -x /bin/revo-gpu ]; then
        /bin/revo-gpu detect
    fi
    
    GPU_DETECTED=0
    GPU_TYPE="cpu"
    
    # Check NVIDIA
    if [ -c /dev/nvidia0 ] || [ -d /sys/module/nvidia ]; then
        GPU_DETECTED=1
        GPU_TYPE="cuda"
        # Load CUDA libs
        [ -d "$GPU_DIR/cuda" ] && export LD_LIBRARY_PATH="$GPU_DIR/cuda:$LD_LIBRARY_PATH"
    fi
    
    # Check AMD
    if [ -d /sys/module/amdgpu ] && [ -d "$GPU_DIR/rocm" ]; then
        GPU_DETECTED=1
        [ "$GPU_TYPE" = "cpu" ] && GPU_TYPE="rocm"
        export LD_LIBRARY_PATH="$GPU_DIR/rocm:$LD_LIBRARY_PATH"
    fi
    
    # Check Vulkan (cross-vendor)
    if [ -c /dev/dri/renderD128 ]; then
        [ "$GPU_DETECTED" -eq 0 ] && GPU_TYPE="vulkan"
    fi
    
    log "GPU: $GPU_TYPE ($([ $GPU_DETECTED -eq 1 ] && echo 'detected' || echo 'not found'))"
}

# ─── v1.6.0: GPU-Aware Inference Flags ───
gpu_inference_flags() {
    local flags=""
    
    case "${GPU_BACKEND:-auto}" in
        cuda|rocm|vulkan|oneapi)
            # Force specific GPU backend
            flags="$flags -ngl 999"  # Offload all layers to GPU
            ;;
        cpu)
            # CPU only
            flags="$flags -ngl 0"
            ;;
        auto)
            # Auto-detect
            if [ "$GPU_DETECTED" -eq 1 ] && [ "$GPU_TYPE" != "cpu" ]; then
                flags="$flags -ngl 999"
                log "GPU auto-detected: $GPU_TYPE — offloading all layers"
            else
                flags="$flags -ngl 0"
                log "No GPU — CPU-only inference"
            fi
            ;;
    esac
    
    # Layer count override
    if [ "${GPU_LAYERS:-0}" -gt 0 ]; then
        flags="-ngl $GPU_LAYERS"
    fi
    
    # Split mode
    if [ -n "$GPU_SPLIT" ]; then
        flags="$flags --tensor-split $GPU_SPLIT"
    fi
    
    echo "$flags"
}

# ─── v1.6.0: Multi-Model Commands ───
cmd_model_list() {
    echo "Available Models — RevoAI Volume"
    echo "================================"
    echo ""
    
    local found=0
    for model in "$MODEL_DIR"/*.gguf; do
        [ -f "$model" ] || continue
        found=1
        local name=$(basename "$model")
        local size=$(du -h "$model" | cut -f1)
        local active=""
        [ "$(readlink "$MODEL_DIR/active.gguf" 2>/dev/null)" = "$model" ] && active=" [ACTIVE]"
        [ "$MODEL_PATH" = "$model" ] && active=" [ACTIVE]"
        echo "  $name  $size$active"
    done
    
    [ "$found" -eq 0 ] && echo "  No models found in $MODEL_DIR"
    echo ""
    echo "Active: $(basename "$MODEL_PATH")"
}

cmd_model_switch() {
    local target="$1"
    [ -z "$target" ] && { echo "Usage: ornetd model switch <model-name>"; return 1; }
    
    # Check if model exists
    local new_path="$MODEL_DIR/$target"
    [ ! -f "$new_path" ] && { 
        echo "Model not found: $target"
        echo "Available models:"
        cmd_model_list
        return 1
    }
    
    echo "Hot-swapping model..."
    echo "  From: $(basename "$MODEL_PATH")"
    echo "  To:   $target"
    
    # Update symlink
    ln -sf "$new_path" "$MODEL_DIR/active.gguf" 2>/dev/null || true
    
    # Update active model path
    export MODEL_FILE="$target"
    export MODEL_PATH="$new_path"
    
    echo "  [OK] Model switched — next inference uses $target"
    echo "  Note: Restart ornetd if daemon is running for full reload"
}

cmd_model_download() {
    local target="$1"
    [ -z "$target" ] && { echo "Usage: ornetd model download <model-name>"; return 1; }
    
    echo "Downloading model: $target"
    echo "From: huggingface.co (searching...)"
    
    # Supported models quick-reference
    case "$target" in
        ornith-9b|ornith-1-9b)
            cmd_download
            return
            ;;
        ornith-35b)
            echo "Ornith-1 35B Q4_K_M (~20 GB)"
            echo "WARNING: Requires ~22 GB VRAM or 24 GB system RAM"
            echo "Download URL: https://huggingface.co/deepreinforce-ai/Ornith-1.0-35B-GGUF"
            ;;
        *)
            echo "Search HuggingFace for: $target"
            echo "Place the .gguf file in: $MODEL_DIR/"
            echo ""
            echo "Supported models:"
            echo "  ornith-9b     — Ornith-1.0 9B Q4_K_M (~5.5 GB)"
            echo "  ornith-35b    — Ornith-1.0 35B Q4_K_M (~20 GB)"
            ;;
    esac
}

# ─── Prerequisites check ───
check_deps() {
    if ! command -v "$LLAMA_CLI" > /dev/null 2>&1; then
        echo "  [!!] llama-cli not found at $LLAMA_CLI"
        echo "  [!!] Install: apk add llama-cpp  OR  compile from source"
        echo "  [!!] See: https://github.com/ggerganov/llama.cpp"
        return 1
    fi
    return 0
}

# ─── Check model availability ───
check_model() {
    if [ ! -f "$MODEL_PATH" ]; then
        echo "  [!!] Model not found: $MODEL_PATH"
        echo "  [!!] Run: ornetd download"
        echo "  [!!] Or place the GGUF manually on the RevoAI volume"
        return 1
    fi
    MODEL_SIZE=$(du -h "$MODEL_PATH" 2>/dev/null | cut -f1)
    echo "  [OK] Model: $MODEL_FILE ($MODEL_SIZE)"
    return 0
}

# ─── Start daemon ───
cmd_start() {
    log "ornetd v$ORNETD_VERSION starting..."
    
    # Check if already running
    if [ -f "$ORNETD_PIDFILE" ] && kill -0 "$(cat $ORNETD_PIDFILE)" 2>/dev/null; then
        log "ornetd already running (PID $(cat $ORNETD_PIDFILE))"
        return 0
    fi
    
    # Mount RevoAI volume if present
    if [ ! -d "$MODEL_DIR" ]; then
        mkdir -p "$MODEL_DIR" 2>/dev/null || true
        # Try mounting dedicated AI partition
        for ai_dev in /dev/sda3 /dev/nvme0n1p3 /dev/vda3; do
            if [ -b "$ai_dev" ]; then
                mount -t ext4 "$ai_dev" "$MODEL_DIR" 2>/dev/null && \
                    log "RevoAI volume: $ai_dev -> $MODEL_DIR" && break
            fi
        done
    fi
    
    # Check dependencies
    check_deps || {
        log "llama-cli not available — ornetd runs in NO-OP mode"
        log "Place llama-cli in /usr/bin/ and restart ornetd"
    }
    
    # Check model
    check_model || {
        log "Model not loaded — ornetd runs in NO-OP mode"
        log "Run 'ornetd download' to fetch Ornith-1 9B"
    }
    
    # Daemonize: write PID, run background inference loop
    echo $$ > "$ORNETD_PIDFILE"
    log "ornetd daemon started (PID $$)"
    log "Model dir: $MODEL_DIR"
    log "Model: ${MODEL_FILE:-none}"
    log "Threads: $DEFAULT_THREADS | Context: $DEFAULT_CTX"
    
    # Background inference loop — reads from named pipe
    rm -f "$ORNETD_SOCKET"
    mkfifo "$ORNETD_SOCKET" 2>/dev/null || true
    
    while true; do
        if read -r line < "$ORNETD_SOCKET" 2>/dev/null; then
            case "$line" in
                "PING") echo "PONG" ;;
                "SHUTDOWN") log "Shutdown signal received"; break ;;
                *)
                    if [ -f "$MODEL_PATH" ] && command -v "$LLAMA_CLI" > /dev/null 2>&1; then
                        log "Inference: ${line:0:80}..."
                        $LLAMA_CLI \
                            -m "$MODEL_PATH" \
                            -p "$line" \
                            -n "$MAX_TOKENS" \
                            -t "$DEFAULT_THREADS" \
                            -c "$DEFAULT_CTX" \
                            --temp "$DEFAULT_TEMP" \
                            --no-display-prompt \
                            2>/dev/null || echo "[ornetd] Inference failed"
                    else
                        echo "[ornetd] Model or llama-cli not available — cannot infer"
                    fi
                    ;;
            esac
        fi
    done
    
    rm -f "$ORNETD_PIDFILE" "$ORNETD_SOCKET"
    log "ornetd stopped"
}

# ─── Stop daemon ───
cmd_stop() {
    if [ -f "$ORNETD_PIDFILE" ]; then
        PID=$(cat "$ORNETD_PIDFILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "SHUTDOWN" > "$ORNETD_SOCKET" 2>/dev/null || true
            kill "$PID" 2>/dev/null
            sleep 1
            kill -9 "$PID" 2>/dev/null || true
            log "ornetd stopped (PID $PID)"
        fi
        rm -f "$ORNETD_PIDFILE" "$ORNETD_SOCKET"
    else
        log "ornetd not running"
    fi
}

# ─── Status ───
cmd_status() {
    echo "ornetd v$ORNETD_VERSION"
    echo ""
    
    if [ -f "$ORNETD_PIDFILE" ] && kill -0 "$(cat $ORNETD_PIDFILE)" 2>/dev/null; then
        echo "Status: RUNNING (PID $(cat $ORNETD_PIDFILE))"
    else
        echo "Status: STOPPED"
    fi
    
    echo "Model dir: $MODEL_DIR"
    echo "Model file: ${MODEL_FILE:-none}"
    
    if [ -f "$MODEL_PATH" ]; then
        SIZE=$(du -h "$MODEL_PATH" 2>/dev/null | cut -f1)
        echo "Model: $MODEL_FILE ($SIZE) — READY"
    else
        echo "Model: NOT DOWNLOADED (run 'ornetd download')"
    fi
    
    echo "llama-cli: $(command -v "$LLAMA_CLI" > /dev/null 2>&1 && echo "FOUND" || echo "MISSING")"
    echo "Threads: $DEFAULT_THREADS | Context: $DEFAULT_CTX | Temp: $DEFAULT_TEMP"
}

# ─── Single inference ───
cmd_infer() {
    PROMPT="$*"
    if [ -z "$PROMPT" ]; then
        echo "Usage: ornetd infer <prompt>"
        return 1
    fi
    
    if [ ! -f "$MODEL_PATH" ]; then
        echo "Error: Model not found. Run 'ornetd download' first."
        return 1
    fi
    
    if ! command -v "$LLAMA_CLI" > /dev/null 2>&1; then
        echo "Error: llama-cli not found at $LLAMA_CLI"
        echo "Install: apk add llama-cpp  OR  compile from https://github.com/ggerganov/llama.cpp"
        return 1
    fi
    
    echo "Ornith-1 9B > $PROMPT"
    echo "---"
    $LLAMA_CLI \
        -m "$MODEL_PATH" \
        -p "$PROMPT" \
        -n "$MAX_TOKENS" \
        -t "$DEFAULT_THREADS" \
        -c "$DEFAULT_CTX" \
        --temp "$DEFAULT_TEMP" \
        --no-display-prompt \
        2>/dev/null
    echo "---"
}

# ─── Interactive chat ───
cmd_chat() {
    if [ ! -f "$MODEL_PATH" ]; then
        echo "Error: Model not found. Run 'ornetd download' first."
        return 1
    fi
    
    if ! command -v "$LLAMA_CLI" > /dev/null 2>&1; then
        echo "Error: llama-cli not found."
        return 1
    fi
    
    echo "Ornith-1 9B Chat — type '/exit' to quit, '/clear' to reset context"
    echo ""
    
    $LLAMA_CLI \
        -m "$MODEL_PATH" \
        -t "$DEFAULT_THREADS" \
        -c "$DEFAULT_CTX" \
        --temp "$DEFAULT_TEMP" \
        --interactive-first \
        --color \
        2>/dev/null
}

# ─── Model info ───
cmd_model_info() {
    if [ ! -f "$MODEL_PATH" ]; then
        echo "Model not found: $MODEL_PATH"
        return 1
    fi
    
    MODEL_SIZE=$(du -h "$MODEL_PATH" 2>/dev/null | cut -f1)
    MODEL_BYTES=$(stat -c%s "$MODEL_PATH" 2>/dev/null || echo "unknown")
    
    echo "Ornet Model Information"
    echo "======================="
    echo "File:      $MODEL_FILE"
    echo "Path:      $MODEL_PATH"
    echo "Size:      $MODEL_SIZE ($MODEL_BYTES bytes)"
    echo "Format:    GGUF (llama.cpp)"
    echo "Quant:     Q4_K_M (4-bit, balanced quality/speed)"
    echo "Base:      Ornith-1.0 9B (DeepReinforce)"
    echo "Params:    ~9 billion"
    echo "Context:   $DEFAULT_CTX tokens"
    echo "RAM:       ~6 GB required"
}

# ─── Download model ───
cmd_download() {
    echo "Ornet Model Download — Ornith-1.0 9B GGUF"
    echo "=========================================="
    echo ""
    echo "Model: $MODEL_FILE (~5.5 GB)"
    echo "From:  huggingface.co/deepreinforce-ai/Ornith-1.0-9B-GGUF"
    echo "To:    $MODEL_PATH"
    echo ""
    
    mkdir -p "$MODEL_DIR" 2>/dev/null || true
    
    # Check if already downloaded
    if [ -f "$MODEL_PATH" ]; then
        MODEL_SIZE=$(du -h "$MODEL_PATH" 2>/dev/null | cut -f1)
        echo "Model already exists: $MODEL_SIZE"
        echo "To re-download, remove it first: rm $MODEL_PATH"
        return 0
    fi
    
    # Check disk space
    if [ -d "$MODEL_DIR" ]; then
        AVAIL=$(df -m "$MODEL_DIR" 2>/dev/null | awk 'NR==2{print $4}')
        if [ -n "$AVAIL" ] && [ "$AVAIL" -lt 6000 ]; then
            echo "Error: Not enough disk space (${AVAIL}MB available, ~6000MB needed)"
            echo "The RevoAI volume needs at least 8 GB"
            return 1
        fi
    fi
    
    # Download using wget or busybox wget
    HF_URL="https://huggingface.co/deepreinforce-ai/Ornith-1.0-9B-GGUF/resolve/main/$MODEL_FILE"
    
    echo "Downloading $MODEL_FILE..."
    echo "This will take a while (~5.5 GB). Press Ctrl+C to cancel."
    echo ""
    
    if command -v wget > /dev/null 2>&1; then
        wget -c --progress=bar "$HF_URL" -O "$MODEL_PATH" 2>&1 || {
            echo "Download failed. Try again — it will resume from where it stopped."
            return 1
        }
    else
        echo "Error: wget not available. Install busybox wget or compile wget."
        echo "Manual download:"
        echo "  $HF_URL"
        echo "  Place at: $MODEL_PATH"
        return 1
    fi
    
    echo ""
    echo "Download complete!"
    MODEL_SIZE=$(du -h "$MODEL_PATH" 2>/dev/null | cut -f1)
    echo "Model: $MODEL_PATH ($MODEL_SIZE)"
    echo ""
    echo "Ornith-1 9B is ready for inference."
    echo "Run: ornetd infer 'Hello, who are you?'"
}

# ─── Version ───
cmd_version() {
    echo "ornetd v$ORNETD_VERSION"
    echo "Part of the Ornet subsystem — Revo OS AI-Native Inferencing"
    echo ""
    echo "Ornet stack:"
    echo "  ornet.ko     — Kernel module: model memory manager, tensor dispatch (~500 KB)"
    echo "  ornetd       — Userspace dispatcher: inference scheduler, priority queues (~10 KB)"
    echo "  Ornith-1 9B  — GGUF Q4_K_M model: dedicated RevoAI volume (~5.5 GB)"
    echo ""
    echo "Model is firmware, not software — dedicated partition, dm-verity integrity."
}

# ─── Main dispatch ───
case "${1:-}" in
    start)
        shift
        # Parse GPU flags
        while [ $# -gt 0 ]; do
            case "$1" in
                --gpu) GPU_BACKEND="$2"; shift 2 ;;
                --cpu-only) GPU_BACKEND="cpu"; shift ;;
                --split) GPU_SPLIT="$2"; shift 2 ;;
                *) break ;;
            esac
        done
        gpu_detect
        cmd_start
        ;;
    stop)     cmd_stop ;;
    status)   gpu_detect; cmd_status ;;
    infer)    shift; cmd_infer "$@" ;;
    chat)     cmd_chat ;;
    model-info) cmd_model_info ;;
    model)
        case "${2:-}" in
            list)     cmd_model_list ;;
            switch)   shift 2; cmd_model_switch "$1" ;;
            download) shift 2; cmd_model_download "$1" ;;
            *) echo "Usage: ornetd model [list|switch|download]"; exit 1 ;;
        esac
        ;;
    download) cmd_download ;;
    version)  cmd_version ;;
    -h|--help|help) usage ;;
    *)
        if [ -z "$1" ]; then
            usage
        else
            echo "Unknown command: $1"
            echo "Run 'ornetd help' for usage."
            exit 1
        fi
        ;;
esac
