#!/bin/busybox sh
# Revo OS v1.6.0 — init script
# Features: dm-verity, CA bundle, containerd, Ornet AI, revo-fs, remote access, GPU
# v1.6: GPU acceleration (CUDA/Vulkan/ROCm), multi-model hot-swap, tensor offload

mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs devtmpfs /dev

# Mount EFI partition for kernel modules + containerd binaries
mkdir -p /boot
mount -t vfat /dev/sda1 /boot 2>/dev/null || true
mount -t vfat /dev/nvme0n1p1 /boot 2>/dev/null || true
mount -t vfat /dev/vda1 /boot 2>/dev/null || true

echo ""
echo "  ╔══════════════════════════════════════╗"
echo "  ║        🌀 REVO OS v1.6.0            ║"
echo "  ║  GPU Accelerated — CUDA · Vulkan · AI║"
echo "  ╚══════════════════════════════════════╝"
echo ""
echo "  Kernel : $(uname -r)"
echo "  Arch   : $(uname -m)"
echo "  CPU    : $(grep -c processor /proc/cpuinfo) cores"
echo "  RAM    : $(awk '/MemTotal/{printf "%.0f", $2/1024}' /proc/meminfo) MB"
echo ""

# Load essential modules from /boot/modules
MODDIR="/boot/modules"
if [ -d "$MODDIR" ]; then
    echo "  [--] Loading kernel modules..."
    for mod in dm-mod dm-verity dm-bufio ext4 overlay vfat loop virtio_blk virtio_net squashfs wireguard; do
        if [ -f "$MODDIR/${mod}.ko.gz" ]; then
            insmod "$MODDIR/${mod}.ko.gz" 2>/dev/null && echo "  [OK] $mod" || true
        fi
    done
# v1.3.1: Ornet kernel module — AI inference engine
ORNET_MODULE="/boot/modules/ornet.ko.gz"
if [ -f "$ORNET_MODULE" ]; then
    insmod "$ORNET_MODULE" 2>/dev/null && {
        echo "  [OK] ornet.ko: kernel module loaded — native inferencing"
        # Create device node (major 240, minor 0)
        mknod /dev/ornet c 240 0 2>/dev/null || true
        chmod 666 /dev/ornet 2>/dev/null || true
        HAS_ORNET_KO=1
    } || {
        echo "  [--] ornet.ko: load failed — check kernel log"
        HAS_ORNET_KO=0
    }
else
    HAS_ORNET_KO=0
fi
fi

# ─── dm-verity: Integrity Verification ───
VERITY_HASH="/boot/verity.hash"
VERITY_ROOT_HASH=""
if [ -f /boot/revo-config.json ]; then
    VERITY_ROOT_HASH=$(grep -o '"verity_root_hash":"[^"]*"' /boot/revo-config.json 2>/dev/null | cut -d'"' -f4)
fi

VERITY_OK=0
if [ -n "$VERITY_ROOT_HASH" ] && [ -f "$VERITY_HASH" ]; then
    echo "  [--] dm-verity: Verifying data integrity..."
    DATA_DEV=""
    for dev in /dev/sda2 /dev/nvme0n1p2 /dev/vda2; do
        if [ -b "$dev" ]; then DATA_DEV="$dev"; break; fi
    done
    if [ -n "$DATA_DEV" ]; then
        DATA_SIZE=$(($(cat /sys/block/${DATA_DEV##*/}/size 2>/dev/null || echo 0) * 512))
        if [ "$DATA_SIZE" -gt 0 ] 2>/dev/null; then
            DATA_BLOCKS=$((DATA_SIZE / 4096))
            dmsetup create revo-verified --table \
                "0 $((DATA_SIZE / 512)) verity 1 $DATA_DEV $DATA_DEV 4096 4096 $DATA_BLOCKS 0 sha256 $VERITY_ROOT_HASH $(echo -n 'RevoOS-dm-verity-v1.3' | hexdump -v -e '/1 \"%02x\"')" \
                2>/dev/null
            if [ -b /dev/mapper/revo-verified ]; then
                echo "  [OK] dm-verity: root hash ${VERITY_ROOT_HASH:0:16}..."
                VERITY_OK=1
            else
                echo "  [!!] dm-verity: verification FAILED"
            fi
        fi
    fi
fi

# Mount persistent storage
DATA_OK=0
mkdir -p /revo
if [ "$VERITY_OK" -eq 1 ] && [ -b /dev/mapper/revo-verified ]; then
    mount -t ext4 /dev/mapper/revo-verified /revo 2>/dev/null && { echo "  [OK] Revo volume: verified -> /revo"; DATA_OK=1; }
fi
if [ "$DATA_OK" -eq 0 ]; then
    for dev in /dev/sda2 /dev/nvme0n1p2 /dev/vda2; do
        if [ -b "$dev" ] && mount -t ext4 "$dev" /revo 2>/dev/null; then
            echo "  [OK] Revo volume: $dev -> /revo (unverified)"; DATA_OK=1; break
        fi
    done
fi
[ "$DATA_OK" -eq 0 ] && echo "  [!!] No Revo volume found (memory-only mode)"

# ─── SSL CA Bundle ───
if [ -d /boot/ssl/certs ]; then
    mkdir -p /etc/ssl/certs
    cp -a /boot/ssl/certs/* /etc/ssl/certs/ 2>/dev/null
    echo "  [OK] SSL CA bundle: $(ls /etc/ssl/certs/ 2>/dev/null | wc -l) certs"
else
    echo "  [--] No CA bundle — TLS will not work"
fi

# ─── v1.2.0: Container Runtime (containerd + runc) ───
CONTAINERD_OK=0
mkdir -p /run/containerd

# Check for containerd on ESP or Revo volume
for cdir in /boot/containerd /revo/containerd /usr/bin; do
    if [ -x "$cdir/containerd" ] && [ -x "$cdir/runc" ]; then
        # Link binaries
        ln -sf "$cdir/containerd" /usr/bin/containerd 2>/dev/null
        ln -sf "$cdir/runc" /usr/bin/runc 2>/dev/null
        [ -x "$cdir/containerd-shim-runc-v2" ] && ln -sf "$cdir/containerd-shim-runc-v2" /usr/bin/containerd-shim-runc-v2 2>/dev/null

        # Create minimal containerd config
        mkdir -p /etc/containerd
        if [ ! -f /etc/containerd/config.toml ]; then
            containerd config default > /etc/containerd/config.toml 2>/dev/null || true
        fi

        # Start containerd in background
        containerd &
        CONTAINERD_PID=$!
        sleep 1

        if kill -0 $CONTAINERD_PID 2>/dev/null; then
            echo "  [OK] containerd: PID $CONTAINERD_PID (from $cdir)"
            CONTAINERD_OK=1
        else
            echo "  [!!] containerd failed to start"
        fi
        break
    fi
done

if [ "$CONTAINERD_OK" -eq 0 ]; then
    echo "  [--] containerd: not found — download via scripts/download-containerd.sh"
    echo "  [--] revocker Docker CLI: available (requires containerd)"
fi

# ─── v1.3.0: Ornet — Kernel-Native AI Inference ───
# Mount RevoAI volume (dedicated AI partition — firmware, not software)
ORNET_OK=0
mkdir -p /revo/ai/models 2>/dev/null || true

for ai_dev in /dev/sda3 /dev/nvme0n1p3 /dev/vda3; do
    if [ -b "$ai_dev" ]; then
        mount -t ext4 "$ai_dev" /revo/ai 2>/dev/null && \
            echo "  [OK] RevoAI volume: $ai_dev -> /revo/ai" && break
    fi
done

# Check for ornetd dispatcher + model
if [ -x /bin/ornetd ]; then
    echo "  [--] Ornet: AI inference dispatcher v1.3.0"

    # Check for kernel-level ornet module
    if [ -e /dev/ornet ]; then
        echo "  [OK] ornet.ko: kernel module loaded — native inferencing"
        HAS_ORNET_KO=1
    else
        echo "  [--] ornet.ko: not loaded — userspace-only mode"
        HAS_ORNET_KO=0
    fi

    # Check for Ornith-1 9B model
    MODEL_PATH="/revo/ai/models/ornith-1.0-9b-Q4_K_M.gguf"
    if [ -f "$MODEL_PATH" ]; then
        MODEL_SIZE=$(du -h "$MODEL_PATH" 2>/dev/null | cut -f1)
        echo "  [OK] Ornith-1 9B: $MODEL_SIZE — model firmware ready"
        HAS_MODEL=1
    else
        echo "  [--] Ornith-1 9B: not downloaded — run 'ornetd download'"
        echo "  [--] Needs ~5.5 GB on RevoAI volume"
        HAS_MODEL=0
    fi

    # Start ornetd daemon if model is available
    if [ "$HAS_MODEL" -eq 1 ]; then
        MODEL_DIR=/revo/ai/models MODEL_FILE=ornith-1.0-9b-Q4_K_M.gguf ornetd start &
        sleep 1
        if [ -f /run/ornetd.pid ] && kill -0 "$(cat /run/ornetd.pid)" 2>/dev/null; then
            echo "  [OK] ornetd: daemon started (PID $(cat /run/ornetd.pid))"
            ORNET_OK=1
        else
            echo "  [!!] ornetd failed to start — check /var/log/ornetd.log"
        fi
    fi
else
    echo "  [--] ornetd: not found in initramfs"
fi

if [ "$ORNET_OK" -eq 0 ]; then
    echo "  [--] Ornet: NO-OP mode — model or dispatcher missing"
    echo "  [--] Run 'ornetd download' after boot to fetch Ornith-1 9B"
fi

# ─── v1.4.0: revo-fs — Package Streaming ───
REVOFS_OK=0
mkdir -p /revo/pkgs /revo/overlay /usr/local/bin /revo/pkgs/db /revo/pkgs/mesh 2>/dev/null || true

if [ -x /bin/revo-fs ]; then
    echo "  [--] revo-fs: Package streaming daemon v1.4.0"
    echo "  [--] \"No apt, no dnf — packages stream on first use\""

    # Mount overlay tmpfs for package mounts
    mount -t tmpfs tmpfs /revo/overlay 2>/dev/null || true
    mount -t tmpfs tmpfs /usr/local 2>/dev/null || true

    # Start revo-fs daemon
    revo-fs start &
    sleep 1
    if [ -f /run/revo-fs.pid ] && kill -0 "$(cat /run/revo-fs.pid)" 2>/dev/null; then
        echo "  [OK] revo-fs: daemon started (PID $(cat /run/revo-fs.pid))"
        echo "  [OK] Package mesh: $MESH_BOOTSTRAP"
        REVOFS_OK=1
    else
        echo "  [!!] revo-fs failed to start"
    fi

    # Ensure /usr/local/bin is in PATH
    export PATH="/usr/local/bin:$PATH"
else
    echo "  [--] revo-fs: not found in initramfs"
fi

if [ "$REVOFS_OK" -eq 0 ]; then
    echo "  [--] revo-fs: NO-OP mode — package streaming unavailable"
    echo "  [--] Run 'revo-fs start' after placing binary"
fi

# ─── v1.5.0: Network Configuration ───
NET_CONF="/revo/etc/network.conf"
if [ -f "$NET_CONF" ]; then
    . "$NET_CONF"
fi
NETWORK_MODE="${NETWORK_MODE:-dhcp}"
SSH_PORT="${SSH_PORT:-2222}"
HOSTNAME="${HOSTNAME:-revo}"

hostname "$HOSTNAME"
ip link set lo up 2>/dev/null

case "$NETWORK_MODE" in
    static)
        echo "  [--] Static IP: ${STATIC_IP:-NOT SET}"
        ip link set "${STATIC_INTERFACE:-eth0}" up 2>/dev/null
        ip addr add "${STATIC_IP:-192.168.1.100}/${STATIC_NETMASK:-255.255.255.0}" \
            dev "${STATIC_INTERFACE:-eth0}" 2>/dev/null && echo "  [OK] IP: ${STATIC_IP:-192.168.1.100}"
        ip route add default via "${STATIC_GATEWAY:-192.168.1.1}" 2>/dev/null && \
            echo "  [OK] Gateway: ${STATIC_GATEWAY:-192.168.1.1}"
        for ns in ${STATIC_DNS:-1.1.1.1}; do
            echo "nameserver $ns" >> /etc/resolv.conf
        done
        echo "  [OK] DNS: ${STATIC_DNS:-1.1.1.1}"
        ;;
    *)
        if ip link set eth0 up 2>/dev/null; then
            udhcpc -q -t 3 -n -i eth0 2>/dev/null && \
                echo "  [OK] eth0: DHCP" || echo "  [--] eth0: no DHCP"
        fi
        ;;
esac

# ─── v1.5.0: SSH Server (Dropbear) ───
SSH_OK=0
DROPBEAR_BIN=""
for dpath in /usr/sbin/dropbear /usr/bin/dropbear /bin/dropbear; do
    [ -x "$dpath" ] && { DROPBEAR_BIN="$dpath"; break; }
done

if [ -n "$DROPBEAR_BIN" ]; then
    echo "  [--] SSH: Dropbear server"
    
    # Generate host keys if missing
    mkdir -p /revo/etc/ssh 2>/dev/null
    if [ ! -f /revo/etc/ssh/dropbear_rsa_host_key ]; then
        dropbearkey -t rsa -f /revo/etc/ssh/dropbear_rsa_host_key 2>/dev/null && \
            echo "  [OK] SSH host key: generated (RSA)" || \
            echo "  [--] SSH host key: keygen failed"
    else
        echo "  [OK] SSH host key: existing"
    fi
    
    # Start dropbear on configured port (default 2222, non-root)
    $DROPBEAR_BIN -p "$SSH_PORT" -B -j -k \
        -r /revo/etc/ssh/dropbear_rsa_host_key &
    DROPBEAR_PID=$!
    sleep 1
    
    if kill -0 $DROPBEAR_PID 2>/dev/null; then
        echo $DROPBEAR_PID > /run/dropbear.pid
        echo "  [OK] SSH: dropbear on port $SSH_PORT (PID $DROPBEAR_PID)"
        SSH_OK=1
    else
        echo "  [!!] SSH: dropbear failed to start"
    fi
else
    echo "  [--] SSH: dropbear not found — download via scripts/download-dropbear.sh"
fi

# ─── v1.5.0: WireGuard ───
WG_OK=0
if [ -x /usr/bin/wg ] || [ -x /bin/wg ]; then
    echo "  [--] WireGuard: VPN tools available"
    
    # Load wireguard kernel module if present
    if [ -f /boot/modules/wireguard.ko.gz ] && [ ! -d /sys/module/wireguard ]; then
        insmod /boot/modules/wireguard.ko.gz 2>/dev/null && \
            echo "  [OK] wireguard.ko: loaded" || \
            echo "  [--] wireguard.ko: may be built-in"
    fi
    
    # Check if WireGuard interface type is available
    if ip link add dev wg0-test type wireguard 2>/dev/null; then
        ip link del wg0-test 2>/dev/null
        echo "  [OK] WireGuard: kernel support confirmed"
        
        # Start WireGuard from config if enabled
        if [ "${WG_ENABLE:-no}" = "yes" ] && [ -f "${WG_CONFIG:-/revo/etc/wg0.conf}" ]; then
            wg-quick up "${WG_CONFIG:-/revo/etc/wg0.conf}" 2>/dev/null && \
                { echo "  [OK] WireGuard: ${WG_INTERFACE:-wg0} up"; WG_OK=1; } || \
                echo "  [!!] WireGuard: config failed"
        else
            echo "  [--] WireGuard: set WG_ENABLE=yes in /revo/etc/network.conf"
        fi
    else
        echo "  [!!] WireGuard: kernel module required (wireguard.ko)"
    fi
else
    echo "  [--] WireGuard: wg tool not found — download via scripts/download-wireguard.sh"
fi

# ─── v1.5.0: iptables Firewall ───
if [ -x /etc/revo/firewall.sh ]; then
    /etc/revo/firewall.sh start 2>/dev/null
else
    echo "  [--] Firewall: script not found — running open"
fi

# ─── v1.5.0: Service Supervision (rc.local) ───
if [ -x /etc/revo/rc.local ]; then
    /etc/revo/rc.local &
    echo "  [OK] rc.local: service supervision started"
fi

echo ""
echo "  ┌──────────────────────────────────────────────────────────┐"
echo "  │  Revo v1.6 — GPU · SSH · VPN · Containers · AI.         │"
if [ "$SSH_OK" -eq 1 ]; then
echo "  │  ssh root@<ip> -p $SSH_PORT                              │"
fi
if [ "$REVOFS_OK" -eq 1 ]; then
echo "  │  revo-fs install python3    (stream on first use)       │"
fi
echo "  │  revocker run alpine:latest sh                           │"
echo "  │  Type 'help' for commands.                               │"
echo "  └──────────────────────────────────────────────────────────┘"
echo ""

# ─── v1.6.0: GPU Detection & Setup ───
GPU_OK=0
if [ -x /bin/revo-gpu ]; then
    echo "  [--] GPU: Running detection..."
    /bin/revo-gpu detect 2>/dev/null
    
    GPU_BACKEND=$(cat /tmp/gpu_backend 2>/dev/null || echo "cpu")
    GPU_STATUS=$(cat /tmp/gpu_status 2>/dev/null || echo "CPU_ONLY")
    GPU_VRAM=$(cat /tmp/gpu_vram 2>/dev/null || echo "0")
    
    case "$GPU_STATUS" in
        READY|DRIVER_ONLY|VULKAN_ONLY)
            echo "  [OK] GPU: $GPU_BACKEND ($GPU_STATUS${GPU_VRAM:+ — $GPU_VRAM})"
            GPU_OK=1
            
            # Load GPU libraries from /revo/gpu/
            if [ -d /revo/gpu ]; then
                for libdir in /revo/gpu/*/; do
                    [ -d "$libdir" ] && export LD_LIBRARY_PATH="$libdir:$LD_LIBRARY_PATH"
                done
                echo "  [OK] GPU libraries: /revo/gpu/ → LD_LIBRARY_PATH"
            fi
            
            # Load NVIDIA kernel modules if present
            for gpu_mod in nvidia nvidia_uvm nvidia_drm; do
                if [ -f "/boot/modules/${gpu_mod}.ko.gz" ] && [ ! -d "/sys/module/$gpu_mod" ]; then
                    insmod "/boot/modules/${gpu_mod}.ko.gz" 2>/dev/null && \
                        echo "  [OK] $gpu_mod.ko: loaded" || true
                fi
            done
            ;;
        CPU_ONLY)
            echo "  [--] GPU: not detected — CPU-only inference"
            ;;
        *)
            echo "  [--] GPU: $GPU_STATUS"
            ;;
    esac
else
    echo "  [--] GPU: revo-gpu not found — CPU-only mode"
fi

exec /bin/sh
