# Revo OS — .gitignore

# Build artifacts
*.img
*.iso
*.raw
build/

# Downloaded binaries
vmlinuz-*
linux-*.apk
busybox-*.apk
*.apk

# Initramfs build directory (at repo root only)
/initramfs/

# Compressed archives (user downloads separately)
*.tar.gz
*.tar.xz
*.zip

# Python cache
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db
*~

# IDE
.vscode/
.idea/
